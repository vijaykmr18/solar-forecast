# Copy this file to .env.local and fill in your values
# For Vercel, add these in Project Settings > Environment Variables

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name (avoid special characters like * in prod)
MONGO_DB_NAME=SolarPower

# OpenRouter API key (get from https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# JWT secret - generate a long random string
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string

# Your app URL (used for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Port (only used for local dev, Vercel ignores this)
PORT=3000
